# Discord bot token — from the Developer Portal → Bot → Token
DISCORD_TOKEN=your_discord_bot_token_here

# Application (client) ID — from the Developer Portal → General Information
CLIENT_ID=your_discord_application_client_id_here

# Guild (server) ID — used for the one-time YAGPDB birthday data migration.
# After the migration runs once this value is no longer required.
GUILD_ID=your_discord_guild_id_here

# ── SassyBot AI features (optional) ─────────────────────────────────────────
# Set SASSY_ENABLED=true to activate Gemini-powered sassy replies and
# unprompted interjections (ported from https://github.com/Stayingfalse/SassyBot).
# Requires a free Google AI Studio API key: https://aistudio.google.com/app/apikey
# Also enable "Server Members Intent" in the Discord Developer Portal → Bot.

# Master toggle — set to true to enable all SassyBot features
SASSY_ENABLED=false

# Google Gemini API key (required when SASSY_ENABLED=true)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model to use (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# ── DeepSeek AI (optional second provider) ───────────────────────────────────
# When provided, SassyBot alternates between Gemini and DeepSeek on every call.
# If one provider fails the other is tried automatically before falling back to
# a canned response.  Uses the OpenAI-compatible API.
# Get a key at: https://platform.deepseek.com/api_keys

# DEEPSEEK_API_KEY=your_deepseek_api_key_here

# DeepSeek model to use (default: deepseek-chat)
# DEEPSEEK_MODEL=deepseek-chat

# DeepSeek API base URL (default: https://api.deepseek.com — change for proxies)
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── MCP context server ────────────────────────────────────────────────────────
# A lightweight HTTP server that exposes user profiles, game stats, conversation
# history, and scoreboards as queryable resources. Starts automatically when
# SASSY_ENABLED=true. Set MCP_ENABLED=false to disable independently.
# MCP_ENABLED=true

# Port the MCP context server listens on inside the container (default: 3100)
# MCP_SERVER_PORT=3100

# Number of days to retain conversation log entries (default: 30)
# CONTEXT_LOG_RETENTION_DAYS=30

# Conversation turns kept per channel for direct replies (default: 20)
# MAX_HISTORY_TURNS=20

# Minimum milliseconds between direct replies per channel (default: 2000)
# COOLDOWN_MS=2000

# Minimum milliseconds between interjections per channel (default: 180000 = 3 min)
# INTERJECT_COOLDOWN=180000

# Rolling window in ms used to measure chat activity for interjections (default: 60000 = 60 sec)
# ACTIVITY_WINDOW_MS=60000

# Comma-separated channel IDs to restrict interjections to specific channels.
# Leave unset to allow interjections in all channels.
# INTERJECT_CHANNELS=123456789012345678,987654321098765432

# Milliseconds of inactivity after which per-channel conversation history and
# state are evicted.  Cleanup runs hourly.  (default: 86400000 = 24 h)
# HISTORY_TTL_MS=86400000

# How many channel messages to accumulate before refreshing AI-generated channel
# topic notes (default: 30).  Set higher to reduce AI calls.
# CHANNEL_NOTES_REFRESH_EVERY=30

# How many user messages to accumulate before refreshing AI-generated user topic
# notes (default: 20).  Set higher to reduce AI calls.
# USER_NOTES_REFRESH_EVERY=20

# ── Admin Dashboard (optional) ────────────────────────────────────────────────
# A web-based admin dashboard that lets server admins toggle bot features and
# restrict them to specific channels.  Authenticate with Discord OAuth2.
#
# Set DASHBOARD_ENABLED=true and fill in the values below to activate.
# Register a redirect URI in the Discord Developer Portal → OAuth2:
#   {DASHBOARD_URL}/dashboard/callback

# Master toggle
DASHBOARD_ENABLED=false

# Port the dashboard HTTP server listens on (default: 3200)
# DASHBOARD_PORT=3200

# Public base URL used to build the OAuth2 redirect URI
# DASHBOARD_URL=http://localhost:3200

# Discord application OAuth2 client ID (falls back to CLIENT_ID if unset)
# DISCORD_CLIENT_ID=your_discord_application_client_id_here

# Discord application OAuth2 client secret (from Developer Portal → OAuth2)
# Prefer DISCORD_CLIENT_SECRET.
# Also accepted for backward compatibility: CLIENT_SECRET, DISCORD_OAUTH_CLIENT_SECRET, OAUTH_CLIENT_SECRET.
# DISCORD_CLIENT_SECRET=your_discord_client_secret_here

# Comma-separated Discord user IDs that can see and manage ALL servers
# SUPER_ADMIN_IDS=123456789012345678,987654321098765432

# Random secret for session tokens (auto-generated at startup if omitted)
# DASHBOARD_SESSION_SECRET=your_random_secret_here
